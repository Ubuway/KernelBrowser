{
  "name": "kernel-browser",
  "version": "1.0.0",
  "description": "Modern browser with Opera GX + Edge style - Powered by Ubuway",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --exec electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.ubuway.kernel",
    "productName": "Kernel Browser",
    "directories": {
      "output": "build"
    },
    "files": ["**/*", "!**/node_modules/*"],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/icon.icns"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icons/icon.png"
    }
  },
  "keywords": ["browser", "electron", "kernel", "ubuway"],
  "author": "Ubuway",
  "license": "MIT",
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "^24.0.0",
    "nodemon": "^3.0.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  }
}